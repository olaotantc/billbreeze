{
  "expo": {
    "name": "BillBreeze",
    "slug": "billbreeze",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "billbreeze",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#004E45"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.billbreeze",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "BillBreeze needs camera access to scan receipts for bill splitting.",
        "NSPhotoLibraryUsageDescription": "BillBreeze needs photo library access to import receipt photos for bill splitting."
      }
    },
    "android": {
      "package": "com.billbreeze",
      "adaptiveIcon": {
        "backgroundColor": "#004E45",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "BillBreeze needs camera access to scan receipts for bill splitting."
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1f715c77-0f38-42e7-8527-93c842abf488"
      }
    }
  }
}
